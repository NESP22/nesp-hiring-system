# Copy this file to docker/.env.production on the server.
# Never commit the real docker/.env.production file.

PHP_VERSION=8.4.1
MARIADB_IMAGE=mariadb:10.11
OPENCATS_HTTP_PORT=8080

DB_NAME=cats
DB_USER=opencats
DB_PASSWORD=REPLACE_WITH_A_RANDOM_32_PLUS_CHARACTER_PASSWORD
DB_ROOT_PASSWORD=REPLACE_WITH_A_DIFFERENT_RANDOM_32_PLUS_CHARACTER_PASSWORD

# Leave blank until the Cloudflare Tunnel is intentionally created.
CLOUDFLARE_TUNNEL_TOKEN=
